{
  "name": "job-hunter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm -w frontend run dev",
    "dev:backend": "npm -w backend run dev",
    "build": "npm -w frontend run build",
    "build:backend": "npm -w backend run build",
    "lint": "eslint .",
    "preview": "npm -w frontend run preview",
    "mock-api": "npm -w frontend run mock-api",
    "test": "npm -w frontend run test",
    "test:run": "npm -w frontend run test:run",
    "test:coverage": "npm -w frontend run test:coverage",
    "test:backend": "npm -w backend run test",
    "test:backend:watch": "npm -w backend run test:watch",
    "test:backend:coverage": "npm -w backend run test:coverage"
  },
  "dependencies": {},
  "devDependencies": {}
}
